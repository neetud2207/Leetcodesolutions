class Solution {
    public int[] frequencySort(int[] nums) {
        int n=nums.length;
        for(int i=0;i<n-1;i++){
            int count1=0;
            for(int k=0;k<n;k++){
                if(nums[i]==nums[k]){
                    count1++;
                }
            }
            for(int j=i+1;j<n;j++){
                int count2=0;
                for(int k=0;k<n;k++){
                    if(nums[j]==nums[k]){
                        count2++;
                    }
                }
                if(count1>count2 || (count1==count2 && nums[i]<nums[j])){

                    int temp=nums[i];
                    nums[i]=nums[j];
                    nums[j]=temp;
                    count1=count2;
                }
              
            }
        }
        return nums;
    }
}
